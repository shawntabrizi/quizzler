{
    "name": "quizzler-app",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Quizzler — social trivia on Polkadot. Triangle product app.",
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=22",
        "pnpm": ">=10"
    },
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "typecheck:tools": "tsc -p tsconfig.tools.json",
        "validate:packs": "tsx scripts/validate-packs.ts",
        "deploy:contract": "tsx scripts/deploy.ts",
        "deploy:registry-migration": "DEPLOY_REGISTRY_MIGRATION=1 tsx scripts/deploy.ts",
        "deploy:e2e-contracts": "DEPLOY_E2E_PROFILE=1 tsx scripts/deploy.ts",
        "seed:packs": "tsx scripts/seed-packs.ts",
        "seed:registry-migration": "SEED_REGISTRY_MIGRATION=1 tsx scripts/seed-packs.ts",
        "promote:registry-migration": "tsx scripts/promote-registry-migration.ts",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui"
    },
    "dependencies": {
        "@parity/product-sdk-address": "^0.1.1",
        "@parity/product-sdk-chain-client": "^0.7.7",
        "@parity/product-sdk-contracts": "^0.8.3",
        "@parity/product-sdk-descriptors": "^0.6.2",
        "@parity/product-sdk-signer": "^0.9.0",
        "emoji-picker-element": "^1.29.1",
        "polkadot-api": "^2.1.8"
    },
    "devDependencies": {
        "@parity/host-api-test-sdk": "^0.10.0",
        "@parity/product-sdk-tx": "^0.2.17",
        "@playwright/test": "^1.50.0",
        "@types/node": "^26.1.1",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "viem": "^2.52.0",
        "vite": "^6.4.3",
        "vitest": "^3.1.4"
    }
}
